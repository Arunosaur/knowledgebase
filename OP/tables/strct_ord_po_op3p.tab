create table STRCT_ORD_PO_OP3P
(
  po_id    NUMBER generated by default on null as identity (cycle nocache order),
  div_part NUMBER not null,
  po_num   VARCHAR2(30) not null,
  use_dt   DATE default TO_DATE('1900-01-01','YYYY-MM-DD') not null
)
;
alter table STRCT_ORD_PO_OP3P
  add constraint PK_OP3P primary key (PO_ID);
alter table STRCT_ORD_PO_OP3P
  add constraint UNQ_OP3P_01 unique (DIV_PART, PO_NUM);

