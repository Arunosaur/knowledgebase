create index FK_OP3M_OP1M_01 on WKLY_MAX_LOG_OP3M (DIV_PART, CUST_ITEM_SID)
  compress;
alter table WKLY_MAX_LOG_OP3M
  add constraint PK_OP3M primary key (DIV_PART, CUST_ITEM_SID, RLSE_TS, ORD_NUM, ORD_LN, QTY_TYP);
alter table WKLY_MAX_LOG_OP3M
  add constraint FK_OP3M_OP1M_01 foreign key (DIV_PART, CUST_ITEM_SID)
  references WKLY_MAX_CUST_ITEM_OP1M (DIV_PART, CUST_ITEM_SID) on delete cascade;
alter table WKLY_MAX_LOG_OP3M
  add constraint MCL_CHK_01_OCT_16_225615268
  check ("RLSE_TS" IS NOT NULL);
alter table WKLY_MAX_LOG_OP3M
  add constraint MCL_CHK_01_OCT_16_225615269
