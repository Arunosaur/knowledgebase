  rlse_ts       DATE,
  ord_num       NUMBER,
  ord_ln        NUMBER(7,2),
  qty_typ       VARCHAR2(3),
  qty           NUMBER,
  div_part      NUMBER(3) default SYS_CONTEXT('userinfo', 'div_part')
)
