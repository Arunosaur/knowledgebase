create table ORDP100A
(
  ordnoa          NUMBER(11) not null,
  custa           VARCHAR2(8),
  cpoa            VARCHAR2(30),
  shpja           NUMBER(6),
  dsorda          VARCHAR2(1),
  pshipa          VARCHAR2(1),
  ldtypa          VARCHAR2(3),
  trndta          NUMBER(6),
  trntma          NUMBER(6),
  ipdtsa          VARCHAR2(8),
  cspasa          VARCHAR2(25),
  stata           VARCHAR2(3),
  telsla          VARCHAR2(20),
  hdexpa          VARCHAR2(3),
  uschga          VARCHAR2(20),
  mntusa          VARCHAR2(20),
  connba          VARCHAR2(25),
  rsncda          VARCHAR2(15),
  legrfa          VARCHAR2(25),
  ord_rcvd_ts     DATE default sysdate,
  excptn_sw       VARCHAR2(1) default 'N',
  load_depart_sid NUMBER default 0,
  div_part        NUMBER(3) default SYS_CONTEXT('userinfo', 'div_part')
)
partition by range (DIV_PART)
(
  partition DIV_PART01 values less than (2)
    tablespace OP_TABLES,
  partition DIV_PART02 values less than (3)
    tablespace OP_TABLES,
  partition DIV_PART03 values less than (4)
    tablespace OP_TABLES,
  partition DIV_PART04 values less than (5)
    tablespace OP_TABLES,
  partition DIV_PART05 values less than (6)
    tablespace OP_TABLES,
  partition DIV_PART06 values less than (7)
    tablespace OP_TABLES,
  partition DIV_PART07 values less than (8)
    tablespace OP_TABLES,
  partition DIV_PART08 values less than (9)
    tablespace OP_TABLES,
  partition DIV_PART09 values less than (10)
    tablespace OP_TABLES,
  partition DIV_PART10 values less than (11)
    tablespace OP_TABLES,
  partition DIV_PART11 values less than (12)
    tablespace OP_TABLES,
  partition DIV_PART12 values less than (13)
    tablespace OP_TABLES,
  partition DIV_PART13 values less than (14)
    tablespace OP_TABLES,
  partition DIV_PART14 values less than (15)
    tablespace OP_TABLES,
  partition DIV_PART15 values less than (16)
    tablespace OP_TABLES,
  partition DIV_PART16 values less than (17)
    tablespace OP_TABLES,
  partition DIV_PART17 values less than (18)
    tablespace OP_TABLES,
  partition DIV_PART18 values less than (19)
    tablespace OP_TABLES,
  partition DIV_PART19 values less than (20)
    tablespace OP_TABLES,
  partition DIV_PART20 values less than (21)
    tablespace OP_TABLES,
  partition DIV_PART21 values less than (22)
    tablespace OP_TABLES,
  partition DIV_PART22 values less than (23)
    tablespace OP_TABLES,
  partition DIV_PART23 values less than (24)
    tablespace OP_TABLES,
  partition DIV_PART24 values less than (25)
    tablespace OP_TABLES,
  partition DIV_PART25 values less than (26)
    tablespace OP_TABLES,
  partition DIV_PART26 values less than (27)
    tablespace OP_TABLES,
  partition DIV_PART27 values less than (28)
    tablespace OP_TABLES,
  partition DIV_PART28 values less than (29)
    tablespace OP_TABLES,
  partition DIV_PART29 values less than (30)
    tablespace OP_TABLES,
  partition DIV_PART30 values less than (31)
    tablespace OP_TABLES,
  partition DIV_PART31 values less than (32)
    tablespace OP_TABLES,
  partition DIV_PART32 values less than (33)
    tablespace OP_TABLES,
  partition DIV_PART33 values less than (34)
    tablespace OP_TABLES,
  partition DIV_PART34 values less than (35)
    tablespace OP_TABLES,
  partition DIV_PART35 values less than (36)
    tablespace OP_TABLES,
  partition DIV_PART36 values less than (37)
    tablespace OP_TABLES,
  partition DIV_PART37 values less than (38)
    tablespace OP_TABLES,
  partition DIV_PART38 values less than (39)
    tablespace OP_TABLES,
  partition DIV_PART39 values less than (40)
    tablespace OP_TABLES,
  partition DIV_PART40 values less than (41)
    tablespace OP_TABLES,
  partition DIV_PART41 values less than (42)
    tablespace OP_TABLES,
  partition DIV_PART42 values less than (43)
    tablespace OP_TABLES,
  partition DIV_PART43 values less than (44)
    tablespace OP_TABLES,
  partition DIV_PART44 values less than (45)
    tablespace OP_TABLES,
  partition DIV_PART45 values less than (46)
    tablespace OP_TABLES,
  partition DIV_PART46 values less than (47)
    tablespace OP_TABLES,
  partition DIV_PART47 values less than (48)
    tablespace OP_TABLES,
  partition DIV_PART48 values less than (49)
    tablespace OP_TABLES,
  partition DIV_PART49 values less than (50)
    tablespace OP_TABLES,
  partition DIV_PART50 values less than (51)
    tablespace OP_TABLES,
  partition DIV_PART51 values less than (52)
    tablespace OP_TABLES,
  partition DIV_OVERFLOW values less than (MAXVALUE)
    tablespace OP_TABLES
);
comment on table ORDP100A
  is 'Warehouse Order Header Table';
comment on column ORDP100A.ordnoa
  is 'Order Number';
comment on column ORDP100A.custa
  is 'Bill To Number';
comment on column ORDP100A.cpoa
  is 'Customer P.O.';
comment on column ORDP100A.shpja
  is 'Req. Ship Date (Julian)';
comment on column ORDP100A.dsorda
  is 'Type Of Order';
comment on column ORDP100A.pshipa
  is 'Ship Complete Only Flag';
comment on column ORDP100A.ldtypa
  is 'Load Type';
comment on column ORDP100A.trndta
  is 'Transmission Date';
comment on column ORDP100A.trntma
  is 'Transmission Time';
comment on column ORDP100A.ipdtsa
  is 'Input Data Source';
comment on column ORDP100A.cspasa
  is 'Customer Pass Through';
comment on column ORDP100A.stata
  is 'Status';
comment on column ORDP100A.telsla
  is 'This is the Serial Number of Telxon Unit.';
comment on column ORDP100A.hdexpa
  is 'Order Header Exception Code';
comment on column ORDP100A.uschga
  is 'User Changed';
comment on column ORDP100A.mntusa
  is 'User Maintaining';
comment on column ORDP100A.connba
  is 'Confirmation Number';
comment on column ORDP100A.rsncda
  is 'Reason Code';
comment on column ORDP100A.excptn_sw
  is 'Exception Switch';
create index N_ORDP100A_01 on ORDP100A (DIV_PART, LOAD_DEPART_SID, CUSTA)
  nologging  local;
create index N_ORDP100A_02 on ORDP100A (STATA, DIV_PART, EXCPTN_SW, LOAD_DEPART_SID, ORDNOA)
  nologging  local;
create index N_ORDP100A_03 on ORDP100A (DIV_PART, STATA, ORDNOA)
  nologging  local;
create index N_ORDP100A_04 on ORDP100A (LOAD_DEPART_SID, CUSTA, STATA, DIV_PART, ORDNOA)
  nologging  local;
create index N_ORDP100A_05 on ORDP100A (STATA)
  compress;
create index N_ORDP100A_06 on ORDP100A (CUSTA)
  compress;
create index N_ORDP100A_07 on ORDP100A (LEGRFA, DIV_PART)
  nologging  local;
create index N_ORDP100A_08 on ORDP100A (EXCPTN_SW, DIV_PART, STATA, LOAD_DEPART_SID, ORDNOA)
  nologging  local;
create index N_ORDP100A_09 on ORDP100A (DSORDA, STATA, EXCPTN_SW, ORD_RCVD_TS);
alter table ORDP100A
  add constraint PK_ORDP100A primary key (DIV_PART, ORDNOA);
alter index PK_ORDP100A nologging;
alter table ORDP100A
  add constraint UNQ_ORDP100A_01 unique (DIV_PART, LOAD_DEPART_SID, EXCPTN_SW, STATA, ORDNOA);
alter index N_ORDP100A_08 nologging;
alter table ORDP100A
  add constraint MCL_CHK_01_OCT_16_225615565
  check ("ORD_RCVD_TS" IS NOT NULL);
alter table ORDP100A
  add constraint MCL_CHK_01_OCT_16_225615566
  check ("EXCPTN_SW" IS NOT NULL);
alter table ORDP100A
  add constraint MCL_CHK_01_OCT_16_225615567
  check ("LOAD_DEPART_SID" IS NOT NULL);
alter table ORDP100A
  add constraint MCL_CHK_01_OCT_16_225615568
  check ("DIV_PART" IS NOT NULL);
alter table ORDP100A
  add constraint ORDP100A_CHK2
  check (EXCPTN_SW in('Y', 'N'));

