  check ("LN_NUM" IS NOT NULL);
alter table PRTCTD_ALLOC_LOG_OP1A
  add constraint MCL_CHK_01_OCT_16_225615136
  check ("QTY" IS NOT NULL);
alter table PRTCTD_ALLOC_LOG_OP1A
  add constraint MCL_CHK_01_OCT_16_225615138
  check ("STAT_CD" IS NOT NULL);
alter table PRTCTD_ALLOC_LOG_OP1A
  add constraint MCL_CHK_01_OCT_16_225615139
