create table CUST_DIST_RTE_EXTR_OP6C
(
  cust_dist_rte_extr_sid NUMBER generated by default on null as identity,
  div_part               NUMBER not null,
  ship_dt_frm            DATE not null,
  ship_dt_to             DATE not null,
  corp_list              CLOB not null,
  last_chg_ts            DATE not null,
  user_id                VARCHAR2(8) not null
)
;
alter table CUST_DIST_RTE_EXTR_OP6C
  add constraint PK_OP6C primary key (CUST_DIST_RTE_EXTR_SID);
alter table CUST_DIST_RTE_EXTR_OP6C
  add constraint FK_OP6C_DV1D_01 foreign key (DIV_PART)
  references DIV_MSTR_DI1D (DIV_PART);

