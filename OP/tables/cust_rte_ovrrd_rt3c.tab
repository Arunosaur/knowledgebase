alter table CUST_RTE_OVRRD_RT3C
  add constraint MCL_CHK_01_OCT_16_225615378
  check ("DEPART_TS" IS NOT NULL);
alter table CUST_RTE_OVRRD_RT3C
  add constraint MCL_CHK_01_OCT_16_225615379
