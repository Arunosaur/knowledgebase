create table MCLP300D
(
  ordnod        NUMBER(11),
  ordlnd        NUMBER(7,2),
  reasnd        VARCHAR2(8),
  descd         VARCHAR2(50),
  exlvld        NUMBER(2),
  itemd         VARCHAR2(25),
  uomd          VARCHAR2(3),
  repitd        VARCHAR2(25),
  repumd        VARCHAR2(3),
  repsbd        VARCHAR2(1),
  qtyfrd        NUMBER(13,4),
  qtytod        NUMBER(13,4),
  exdtd         NUMBER(2),
  exmond        NUMBER(2),
  exyerd        NUMBER(4),
  extimd        NUMBER(6),
  resexd        VARCHAR2(2),
  exdesd        VARCHAR2(40),
  resusd        VARCHAR2(20),
  resdtd        NUMBER(6),
  restmd        NUMBER(6),
  last_chg_ts   DATE default SYSDATE,
  div_part      NUMBER(3) default SYS_CONTEXT('userinfo', 'div_part'),
  excptn_log_id NUMBER generated by default on null as identity (cycle nocache order)
)
compress for all operations;
comment on table MCLP300D
  is 'Usage: Holds order and line level exception messages.
';
comment on column MCLP300D.descd
  is 'A brief description of the EXCEPTION specified.';
comment on column MCLP300D.exlvld
  is 'This is the Level of Exception.';
comment on column MCLP300D.itemd
  is 'This is the CBR Item Number.';
comment on column MCLP300D.uomd
  is 'This is the Item Unit of Measure.';
comment on column MCLP300D.repitd
  is 'This is the Replaced CBR Item Number.';
comment on column MCLP300D.repumd
  is 'This is the Replaced Item Unit of Measure.';
comment on column MCLP300D.exdesd
  is 'A brief description of the EXCEPTION specified.';
comment on column MCLP300D.excptn_log_id
  is 'An unique identifier of the exception log record. This is system generated.';
create index N_MCLP300D_01 on MCLP300D (DIV_PART, ORDNOD)
  compress;
create index N_MCLP300D_02 on MCLP300D (ORDNOD, DIV_PART, REASND)
  compress;
create index N_MCLP300D_03 on MCLP300D (REASND, DIV_PART, ITEMD, UOMD);
create index N_MCLP300D_04 on MCLP300D (ORDLND, RESEXD, DIV_PART, ORDNOD);
create index N_MCLP300D_05 on MCLP300D (REASND);
create index N_MCLP300D_06 on MCLP300D (DIV_PART, REASND, ORDNOD, ORDLND, LAST_CHG_TS);
alter table MCLP300D
  add constraint PK_MCLP300D primary key (EXCPTN_LOG_ID);
alter table MCLP300D
  add constraint MCL_CHK_01_OCT_16_225615222
  check ("LAST_CHG_TS" IS NOT NULL);
alter table MCLP300D
  add constraint MCL_CHK_01_OCT_16_225615226
  check ("DIV_PART" IS NOT NULL);

