CREATE OR REPLACE TYPE "KIT_T"                                          AS OBJECT( div_id VARCHAR2(2), llr_dt NUMBER(6), kit_typ VARCHAR2(3), ord_typ VARCHAR2(1), kit_item_num VARCHAR2(6), cust_num VARCHAR2(8), load_num VARCHAR2(4), stop_num NUMBER(7), eta_date NUMBER(6), po_num VARCHAR2(30) );
/

