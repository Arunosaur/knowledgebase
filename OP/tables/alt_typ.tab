alter table ALT_TYP
  add constraint MCL_CHK_01_OCT_16_225615477
  check ("ALT_TYP" IS NOT NULL);
alter table ALT_TYP
  add constraint MCL_CHK_01_OCT_16_225615478
  check ("DESCR" IS NOT NULL);

